# OpenViking配置
OPENVIKING_BASE_URL=http://localhost:1933
OPENVIKING_API_KEY=your-api-key

# Ollama配置
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=bge-m3

# 导出配置
EXPORT_INTERVAL_MINUTES=60
EXPORT_DIR=~/.agents_mem/export

# 数据库配置 (可选，默认 ~/.agents_mem/agents_mem.db)
# AGENTS_MEM_DB=/path/to/custom.db
