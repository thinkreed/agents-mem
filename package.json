{
  "name": "agents-mem",
  "version": "1.0.0",
  "description": "Six-layer progressive disclosure memory system for 169+ agents",
  "type": "module",
  "scripts": {
    "build": "bun build src/mcp_server.ts --outdir dist --target bun --minify",
    "start": "bun run dist/mcp_server.js",
    "dev": "bun run src/mcp_server.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint:deps": "bun run scripts/lint-dependencies.ts",
    "lint:docs": "bun run scripts/lint-docs.ts",
    "doc:garden": "bun run scripts/doc-gardener.ts",
    "clean": "bun x rimraf dist",
    "prebuild": "bun x rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.3.12",
    "rimraf": "^6.1.3"
  },
  "bin": {
    "agents-mem": "./src/mcp_server.ts"
  }
}